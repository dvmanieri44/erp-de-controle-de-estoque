# Core auth/session
AUTH_SECRET=replace-with-a-strong-random-secret-with-at-least-32-chars
ALLOW_INSECURE_DEV_AUTH_SECRET=false

# Generic ERP state fallback
ERP_STATE_FILE_PATH=.data/erp-state.json
AUTH_CREDENTIALS_FILE_PATH=.data/auth-credentials.json
RATE_LIMIT_FILE_PATH=.data/rate-limits.json
AUDIT_LOG_FILE_PATH=.data/audit-log.ndjson
PASSWORD_RESET_FILE_PATH=.data/password-reset-tokens.json

# Dedicated item store fallback files
OPERATIONS_PRODUCTS_FILE_PATH=.data/operations-products.json
INVENTORY_LOTS_FILE_PATH=.data/inventory-lots.json
INVENTORY_LOCATIONS_FILE_PATH=.data/inventory-locations.json
INVENTORY_MOVEMENTS_FILE_PATH=.data/inventory-movements.json
QUALITY_EVENTS_FILE_PATH=.data/quality-events.json
INCIDENTS_FILE_PATH=.data/incidents.json
PENDING_FILE_PATH=.data/pending-items.json
TASKS_FILE_PATH=.data/tasks.json
DOCUMENTS_FILE_PATH=.data/documents.json

# Password reset
PASSWORD_RESET_BASE_URL=http://localhost:3000
ENABLE_DEBUG_RESET_LINKS=false

# Optional first admin bootstrap
BOOTSTRAP_ADMIN_PASSWORD=

# Development-only team seed used by `npm run seed:dev-users`
# The temporary accounts are documented in README and are never bootstrapped in production.
NEXT_PUBLIC_ENABLE_DEV_CREDENTIAL_HINTS=false

# Firebase Admin (recommended for shared/team environments)
# Preferred option: full service account JSON in base64
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Alternative: raw service account JSON
FIREBASE_SERVICE_ACCOUNT_JSON=

# Legacy split fields
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
